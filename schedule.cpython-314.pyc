from fastapi import APIRouter, Depends, HTTPException, UploadFile, File
from fastapi.responses import FileResponse
from sqlalchemy.orm import Session
from app.dependencies import get_current_user
from app.database import get_db
from app import models, schemas
from app.utils import file_utils
from typing import List
import os

router = APIRouter(prefix="/notes/{note_id}/attachments", tags=["Attachments"])


@router.post("/", response_model=schemas.Attachment)
async def upload_attachment(
    note_id: int,
    file: UploadFile = File(...),
    current_user: models.User = Depends(get_current_user),
    db: Session = Depends(get_db)
):
    # Проверка заметки
    note = db.query(models.Note).filter(
        models.Note.id == note_id,
        models.Note.user_id == current_user.id
    ).first()
    if not note:
        raise HTTPException(404, "Заметка не найдена или не принадлежит вам")

    # Сохранение файла
    try:
        file_meta = await file_utils.save_upload_file(file, current_user.id, note_id)
    except HTTPException as e:
        raise e
    except Exception as e:
        raise HTTPException(500, f"Ошибка сохранения файла: {str(e)}")

    # Запись в БД
    attachment = models.Attachment(
        note_id=note_id,
        file_name=file_meta["file_name"],
        stored_name=file_meta["stored_name"],
        mime_type=file_meta["mime_type"],
        size=file_meta["size"]
    )
    db.add(attachment)
    db.commit()
    db.refresh(attachment)
    return attachment


@router.get("/", response_model=List[schemas.Attachment])
async def get_attachments(
    note_id: int,
    current_user: models.User = Depends(get_current_user),
    db: Session = Depends(get_db)
):
    note = db.query(models.Note).filter(
        models.Note.id == note_id,
        models.Note.user_id == current_user.id
    ).first()
    if not note:
        raise HTTPException(404, "Заметка не найдена")
    return note.attachments


@router.get("/{attachment_id}", response_class=FileResponse)
async def download_attachment(
    note_id: int,
    attachment_id: int,
    current_user: models.User = Depends(get_current_user),
    db: Session = Depends(get_db)
):
    note = db.query(models.Note).filter(
        models.Note.id == note_id,
        models.Note.user_id == current_user.id
    ).first()
    if not note:
        raise HTTPException(404, "Заметка не найдена")

    attachment = db.query(models.Attachment).filter(
        models.Attachment.id == attachment_id,
        models.Attachment.note_id == note_id
    ).first()
    if not attachment:
        raise HTTPException(404, "Вложение не найдено")

    # Поиск файла на диске
    for root, dirs, files in os.walk(file_utils.UPLOAD_DIR):
        if attachment.stored_name in files:
            file_path = os.path.join(root, attachment.stored_name)
            return FileResponse(
                path=file_path,
                filename=attachment.file_name,
                media_type=attachment.mime_type
            )
    raise HTTPException(404, "Файл не найден на диске")


@router.delete("/{attachment_id}", status_code=204)
async def delete_attachment(
    note_id: int,
    attachment_id: int,
    current_user: models.User = Depends(get_current_user),
    db: Session = Depends(get_db)
):
    note = db.query(models.Note).filter(
        models.Note.id == note_id,
        models.Note.user_id == current_user.id
    ).first()
    if not note:
        raise HTTPException(404, "Заметка не найдена")

    attachment = db.query(models.Attachment).filter(
        models.Attachment.id == attachment_id,
        models.Attachment.note_id == note_id
    ).first()
    if not attachment:
        raise HTTPException(404, "Вложение не найдено")

    # Удаляем файл
    file_utils.delete_attachment_file(attachment.stored_name)

    db.delete(attachment)
    db.commit()
    return None