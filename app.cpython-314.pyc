import streamlit as st
import requests
from datetime import datetime

# Конфигурация
API_BASE = "http://localhost:8000/api"

# Инициализация состояния
if "token" not in st.session_state:
    st.session_state.token = None
if "user_id" not in st.session_state:
    st.session_state.user_id = None
if "nickname" not in st.session_state:
    st.session_state.nickname = None


def api_request(method, endpoint, **kwargs):
    """Выполнение запроса к API"""
    url = f"{API_BASE}{endpoint}"
    headers = kwargs.pop("headers", {})
    
    if st.session_state.token:
        headers["Authorization"] = f"Bearer {st.session_state.token}"
    
    try:
        response = requests.request(method, url, headers=headers, **kwargs)
        return response
    except requests.exceptions.ConnectionError:
        st.error("Не удалось подключиться к серверу. Убедитесь, что сервер запущен.")
        return None


def logout():
    """Выход из аккаунта"""
    st.session_state.token = None
    st.session_state.user_id = None
    st.session_state.nickname = None
    st.rerun()


# Навигация
st.set_page_config(
    page_title="Mintellect",
    page_icon="🐺",
    layout="wide"
)

if not st.session_state.token:
    # Страница входа/регистрации
    tab_login, tab_register = st.tabs(["Вход", "Регистрация"])
    
    with tab_login:
        st.header("Вход")
        login = st.text_input("Логин", key="login_input")
        password = st.text_input("Пароль", type="password", key="password_input")
        
        if st.button("Войти"):
            response = api_request("POST", "/login", json={"login": login, "password": password})
            if response and response.status_code == 200:
                data = response.json()
                st.session_state.token = data["access_token"]
                st.session_state.user_id = data["user_id"]
                st.session_state.nickname = data["nickname"]
                st.success("Вход выполнен!")
                st.rerun()
            elif response and response.status_code == 401:
                st.error("Неверный логин или пароль")
            elif response:
                st.error(f"Ошибка: {response.text}")
    
    with tab_register:
        st.header("Регистрация")
        reg_nickname = st.text_input("Никнейм", key="reg_nickname")
        reg_login = st.text_input("Логин", key="reg_login")
        reg_password = st.text_input("Пароль", type="password", key="reg_password")
        
        if st.button("Зарегистрироваться"):
            response = api_request("POST", "/register", json={
                "nickname": reg_nickname,
                "login": reg_login,
                "password": reg_password
            })
            if response and response.status_code == 201:
                st.success("Регистрация успешна! Теперь войдите.")
            elif response and response.status_code == 400:
                st.error("Логин уже занят")
            elif response:
                st.error(f"Ошибка: {response.text}")

else:
    # Основное приложение
    st.sidebar.title(f"🐺 Mintellect")
    st.sidebar.write(f"Привет, **{st.session_state.nickname}**!")
    
    # Меню
    page = st.sidebar.radio(
        "Навигация",
        ["Главная", "Расписание", "Заметки", "Группы", "Настройки"]
    )
    
    st.sidebar.divider()
    if st.sidebar.button("Выйти"):
        logout()
    
    # Отображение страниц
    if page == "Главная":
        exec(open("pages/home.py").read())
    elif page == "Расписание":
        exec(open("pages/schedule.py").read())
    elif page == "Заметки":
        exec(open("pages/notes.py").read())
    elif page == "Группы":
        exec(open("pages/groups.py").read())
    elif page == "Настройки":
        exec(open("pages/settings.py").read())