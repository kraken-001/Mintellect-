from datetime import datetime, timedelta, timezone
from fastapi import Depends, HTTPException, status
from fastapi.security import HTTPBearer, HTTPAuthorizationCredentials
from sqlalchemy.orm import Session
from app.database import get_db
from app import models

security = HTTPBearer()

def get_current_user(
        credentials: HTTPAuthorizationCredentials = Depends(security),
        db: Session = Depends(get_db)
):
    """Зависимость для получения текущего пользователя по токену"""
    token = credentials.credentials

    # Находим сессию по токену
    session = db.query(models.Session).filter(
        models.Session.access_token == token
    ).first()

    if not session:
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Неверный токен авторизации",
            headers={"WWW-Authenticate": "Bearer"},
        )

    # Проверяем, не истекла ли сессия
    if session.expires_at.replace(tzinfo=timezone.utc) < datetime.now(timezone.utc):
        # Удаляем просроченную сессию
        db.delete(session)
        db.commit()
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Токен истек",
            headers={"WWW-Authenticate": "Bearer"},
        )

    # Продлеваем токен на 30 минут при каждом запросе
    session.expires_at = datetime.now(timezone.utc) + timedelta(seconds=1800)
    db.commit()

    # Получаем пользователя
    user = db.query(models.User).filter(
        models.User.id == session.user_id
    ).first()

    if not user:
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Пользователь не найден",
            headers={"WWW-Authenticate": "Bearer"},
        )

    return user